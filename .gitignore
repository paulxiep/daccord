# Root-level scratch markdown — default to ignore, README.md is the exception
/*.md
!/README.md
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
# Per-env venvs for tier sub-projects (e.g. envs/bakeoff/.venv for tier 2D).
# Each envs/<tier>/ is an independent uv project with its own lockfile + venv.
envs/*/.venv/
build/
dist/

# Environment / secrets
.env
.env.local
*.secret

# MLflow tracking
mlruns/
mlartifacts/

# Notebooks
.ipynb_checkpoints/

# Data — raw PDFs gitignored (sourced via scripts/download_corpus.py +
# data/sources.yaml); ensemble + tiering + splits gitignored (regenerated).
# Parsed markdown (data/ingest/) IS committed: ~4 MB total, unblocks tier 5+
# work for contributors without a GPU (re-parsing requires Marker + ~37 min).
# Only data/gold/ (hand-validated mapping pairs) + per-stage manifests are
# committed for the other stages.
/data/raw/
/data/parsed/
/data/registry/
/data/ensemble/
/data/tiering/
/data/splits/
/data/gold/snapshots/
# Gold drafter intermediate outputs (LLM proposals before human reconcile/verify)
/data/gold/*.draft_*.jsonl

# Parser bake-off (tier 2D): per-page parser outputs + rasterized images are
# large and reproducible. Only the M1 artifacts are committed:
#   sample_pages.json, expected_citation_ids.json, score_table.csv, summary.md
/data/parser_bakeoff/marker/
/data/parser_bakeoff/typhoon/
/data/parser_bakeoff/page_images/

# Costs — inflight sqlite log and lock files; daily.csv + config.toml are committed
/costs/inflight.sqlite
/costs/inflight.sqlite-*
/costs/*.lock

# Models — never commit weights/adapters
/models/
*.bin
*.safetensors
*.gguf
*.pt
*.pth
adapter/
checkpoints/

# Training artifacts
/training/runs/
/training/outputs/
/training/logs/

# Eval outputs — raw traces gitignored; results.csv committed
/eval/traces/
/eval/raw/

# Publish staging
/publish/staging/

# Caravan-generated (mirrors code-rag pattern)
/infra/
/caravan.exe

# Cache
/.cache/
.fastembed_cache/

# Editors / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
