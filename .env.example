# D'accord environment template.
# Copy to .env.local (gitignored) and fill in. .env.local is loaded by all
# scripts that import settings; the tracking layer also reads it directly.
#
# Each tier-1 task appends its own section here. Do not rewrite other sections.

# --- MLflow (tier 1B) -------------------------------------------------------
# Phase 1 default: local file store under ./mlruns (gitignored).
# Phase 2: change to a remote tracking server URI; no code edits needed.
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=daccord-qlora

# --- Free-tier OSS ensemble providers (tier 2A drafter + tier 7A ensemble) -
# Phase 1 ensemble + LLM-as-judge run on open-source models via free-tier APIs.
# Get keys at:
#   Groq:           https://console.groq.com/keys
#   Google AI Studio: https://aistudio.google.com/apikey
GROQ_API_KEY=
GOOGLE_API_KEY=
